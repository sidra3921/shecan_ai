    {
      "name": "🤖 OpenAI",
      "description": "OpenAI API for AI resume builder and chat bot",
      "item": [
        {
          "name": "1. Generate AI Resume",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{openai_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"gpt-3.5-turbo\",\n  \"temperature\": 0.7,\n  \"max_tokens\": 1000,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a professional resume writer. Create a well-formatted resume based on provided information.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Create a professional resume for: Name: John Doe, Skills: JavaScript, React, Node.js, Firebase. Experience: 5 years as Full Stack Developer at Tech Company.\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://api.openai.com/v1/chat/completions",
              "protocol": "https",
              "host": ["api", "openai", "com"],
              "path": ["v1", "chat", "completions"]
            },
            "description": "Generate a professional AI resume from user profile data"
          }
        },
        {
          "name": "2. Chat Bot Query",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{openai_api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"gpt-3.5-turbo\",\n  \"temperature\": 0.8,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful mentor for freelancers on Shecan AI. Provide advice on: gig work, payment issues, skill improvement, and career tips. Be concise and practical.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"How can I improve my profile to get more projects?\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "https://api.openai.com/v1/chat/completions",
              "protocol": "https",
              "host": ["api", "openai", "com"],
              "path": ["v1", "chat", "completions"]
            },
            "description": "Query the AI chat bot for freelancer advice and tips"
          }
        },
        {
          "name": "3. Transcribe Audio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{openai_api_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "model",
                  "value": "whisper-1",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://api.openai.com/v1/audio/transcriptions",
              "protocol": "https",
              "host": ["api", "openai", "com"],
              "path": ["v1", "audio", "transcriptions"]
            },
            "description": "Transcribe audio file to text using Whisper model"
          }
        }
      ]
    },
    {
      "name": "🏆 Assessments & Skills",
      "description": "Skill assessment endpoints",
      "item": [
        {
          "name": "1. Submit Assessment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{id_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
