{
  "info": {
    "_postman_id": "shecan-ai-apis",
    "name": "Shecan AI - Complete API Integration",
    "description": "Complete collection for testing all 8 Tier 1 features:\n1. Real-Time Chat (Firebase)\n2. Video Consultations (Twilio/Agora)\n3. Skill Assessments\n4. Payment Processing (Stripe)\n5. AI Resume Builder (OpenAI)\n6. AI Chat Bot\n7. Smart Recommendations\n8. Reviews & Fraud Detection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "Firebase authentication endpoints",
      "item": [
        {
          "name": "1. Sign Up (Create User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"securePassword123\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebase_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signUp"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebase_api_key}}"
                }
              ]
            },
            "description": "Create a new Firebase user account"
          }
        },
        {
          "name": "2. Sign In (Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebase_api_key}}"
                }
              ]
            },
            "description": "Sign in user and get ID token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"id_token\", jsonData.idToken);",
                  "    pm.environment.set(\"refresh_token\", jsonData.refreshToken);",
                  "    pm.test(\"✓ Login successful - ID token saved\", function () {",
                  "        pm.expect(jsonData.idToken).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"refresh_token\",\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "https://securetoken.googleapis.com/v1/token?key={{firebase_api_key}}",
              "protocol": "https",
              "host": ["securetoken", "googleapis", "com"],
              "path": ["v1", "token"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebase_api_key}}"
                }
              ]
            },
            "description": "Refresh expired ID token"
          }
        }
      ]
    },
    {
      "name": "💬 Chat & Messaging",
      "description": "Firebase Firestore chat endpoints",
      "item": [
        {
          "name": "1. Create Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{id_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"participantIds\": {\n      \"arrayValue\": {\n        \"values\": [\n          {\"stringValue\": \"user_123\"},\n          {\"stringValue\": \"user_456\"}\n        ]\n      }\n    },\n    \"participantNames\": {\n      \"mapValue\": {\n        \"fields\": {\n          \"user_123\": {\"stringValue\": \"John Doe\"},\n          \"user_456\": {\"stringValue\": \"Jane Smith\"}\n        }\n      }\n    },\n    \"participantAvatars\": {\n      \"mapValue\": {\n        \"fields\": {\n          \"user_123\": {\"stringValue\": \"https://via.placeholder.com/40?text=JD\"},\n          \"user_456\": {\"stringValue\": \"https://via.placeholder.com/40?text=JS\"}\n        }\n      }\n    },\n    \"lastMessage\": {\"stringValue\": \"\"},\n    \"lastMessageTimestamp\": {\"timestampValue\": \"2024-01-15T10:00:00Z\"},\n    \"lastMessageSenderId\": {\"stringValue\": \"\"},\n    \"unreadCount\": {\"integerValue\": \"0\"},\n    \"createdAt\": {\"timestampValue\": \"2024-01-15T10:00:00Z\"}\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/conversations",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "conversations"]
            },
            "description": "Create a new conversation between two users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    var docId = jsonData.name.split('/').pop();",
                  "    pm.environment.set(\"conversation_id\", docId);",
                  "    pm.test(\"✓ Conversation created\", function () {",
                  "        pm.expect(jsonData.createTime).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{id_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"senderId\": {\"stringValue\": \"user_123\"},\n    \"senderName\": {\"stringValue\": \"John Doe\"},\n    \"senderAvatar\": {\"stringValue\": \"https://via.placeholder.com/40?text=JD\"},\n    \"content\": {\"stringValue\": \"Hello! How are you?\"},\n    \"timestamp\": {\"timestampValue\": \"2024-01-15T10:35:00Z\"},\n    \"readBy\": {\n      \"arrayValue\": {\n        \"values\": []\n      }\n    },\n    \"isRead\": {\"booleanValue\": false}\n  }\n}"
            },
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/conversations/{{conversation_id}}/messages",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "conversations", "{{conversation_id}}", "messages"]
            },
            "description": "Send a message in a conversation"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"✓ Message sent\", function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Get All Conversations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{id_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/conversations",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "conversations"]
            },
            "description": "Retrieve all conversations for the user"
          }
        },
        {
          "name": "4. Get Messages in Conversation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{id_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://firestore.googleapis.com/v1/projects/{{firebase_project_id}}/databases/(default)/documents/conversations/{{conversation_id}}/messages",
              "protocol": "https",
              "host": ["firestore", "googleapis", "com"],
              "path": ["v1", "projects", "{{firebase_project_id}}", "databases", "(default)", "documents", "conversations", "{{conversation_id}}", "messages"]
            },
            "description": "Get all messages in a specific conversation"
          }
        }
      ]
    },
    {
      "name": "💳 Stripe Payment",
      "description": "Stripe payment processing endpoints",
      "item": [
        {
          "name": "1. Create Payment Intent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{stripe_secret_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "amount",
                  "value": "5000",
                  "type": "text"
                },
                {
                  "key": "currency",
                  "value": "usd",
                  "type": "text"
                },
                {
                  "key": "payment_method_types[]",
                  "value": "card",
                  "type": "text"
                },
                {
                  "key": "metadata[projectId]",
                  "value": "proj_123",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Payment for Project Design Work",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://api.stripe.com/v1/payment_intents",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "payment_intents"]
            },
            "description": "Create a payment intent for processing a payment"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"payment_intent_id\", jsonData.id);",
                  "    pm.environment.set(\"client_secret\", jsonData.client_secret);",
                  "    pm.test(\"✓ Payment intent created\", function () {",
                  "        pm.expect(jsonData.id).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{stripe_secret_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "payment_method",
                  "value": "pm_card_visa",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://api.stripe.com/v1/payment_intents/{{payment_intent_id}}/confirm",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "payment_intents", "{{payment_intent_id}}", "confirm"]
            },
            "description": "Confirm a payment intent with a payment method. Use Stripe test cards:\n- Success: 4242 4242 4242 4242\n- Decline: 4000 0000 0000 9995"
          }
        },
        {
          "name": "3. Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{stripe_secret_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://api.stripe.com/v1/payment_intents/{{payment_intent_id}}",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "payment_intents", "{{payment_intent_id}}"]
            },
            "description": "Check the status of a payment intent"
          }
        },
        {
          "name": "4. Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{stripe_secret_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "customer@example.com",
                  "type": "text"
                },
                {
                  "key": "name",
                  "value": "John Doe",
                  "type": "text"
                },
                {
                  "key": "metadata[userId]",
                  "value": "user_123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://api.stripe.com/v1/customers",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "customers"]
            },
            "description": "Create a Stripe customer for tracking recurring payments"
          }
        },
        {
          "name": "5. List Charges",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{stripe_secret_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://api.stripe.com/v1/charges?limit=10",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "charges"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List recent Stripe charges"
          }
        }
      ]
    },
    {
      "name": "📹 Twilio Video",
      "description": "Twilio video consultation endpoints",
      "item": [
        {
          "name": "1. Generate Video Room Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Basic Auth: Account SID:Auth Token",
                  "var credentials = pm.environment.get(\"twilio_account_sid\") + ':' + pm.environment.get(\"twilio_auth_token\");",
                  "var encodedCredentials = btoa(credentials);",
                  "pm.request.headers.add({",
                  "  key: 'Authorization',",
                  "  value: 'Basic ' + encodedCredentials",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "Identity",
                  "value": "user_123",
                  "type": "text"
                },
                {
                  "key": "VideoGrant",
                  "value": "{\"room\": \"consultation_room\", \"maxParticipants\": 2}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://api.twilio.com/2010-04-01/Accounts/{{twilio_account_sid}}/Tokens",
              "protocol": "https",
              "host": ["api", "twilio", "com"],
              "path": ["2010-04-01", "Accounts", "{{twilio_account_sid}}", "Tokens"]
            },
            "description": "Generate a Twilio video room token for consultations"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"video_token\", jsonData.token);",
                  "    pm.test(\"✓ Video token generated\", function () {",
                  "        pm.expect(jsonData.token).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. List Active Rooms",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var credentials = pm.environment.get(\"twilio_account_sid\") + ':' + pm.environment.get(\"twilio_auth_token\");",
                  "var encodedCredentials = btoa(credentials);",
                  "pm.request.headers.add({",
                  "  key: 'Authorization',",
                  "  value: 'Basic ' + encodedCredentials",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://video.twilio.com/v1/Rooms?Status=in-progress&limit=10",
              "protocol": "https",
              "host": ["video", "twilio", "com"],
              "path": ["v1", "Rooms"],
              "query": [
                {
                  "key": "Status",
                  "value": "in-progress"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List currently active video rooms"
          }
        }
      ]
    },
